# Public site URL used for metadata, sitemap, and canonical links
NEXT_PUBLIC_APP_URL=https://tab-graveyard0.vercel.app

# Google AI Studio key for Gemini 2.5 Flash
GEMINI_API_KEY=

# Upstash Redis REST URL and token from your Redis database settings
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Supabase project URL and browser anon key from Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key from Project Settings > API
SUPABASE_SERVICE_ROLE_KEY=
